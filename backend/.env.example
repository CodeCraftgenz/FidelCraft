# ============================================================
# FidelCraft - Backend Environment Variables
# ============================================================

# App
NODE_ENV=development
PORT=3002

# Database (MySQL)
DATABASE_URL="mysql://fidelcraft:fidelcraft_pass@localhost:3308/fidelcraft"

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Mercado Pago
MP_ACCESS_TOKEN=your-mercado-pago-access-token
MP_WEBHOOK_SECRET=your-webhook-secret
MP_PUBLIC_KEY=your-public-key

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=fidelcraft
R2_PUBLIC_URL=https://your-r2-public-url

# Email (SMTP)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USER=your-email@domain.com
MAIL_PASS=your-email-password

# Web Push (VAPID)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@domain.com

# URLs
FRONTEND_URL=http://localhost:5174
BACKEND_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:5174

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
